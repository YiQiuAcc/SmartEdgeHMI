<Window
    x:Class="SmartEdgeHMI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SmartEdgeHMI.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:SmartEdgeHMI.ViewModels"
    x:Name="RootWindow"
    Title="SmartEdgeHMI"
    Width="900"
    Height="600"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!--  连接控制区域  -->
        <controls:ConnectionBarView Grid.Row="0" />

        <!--  图表区域  -->
        <controls:ChartView Grid.Row="1" DataContext="{Binding Chart}" />

        <!--  底部面板: 监控 + 报警/日志  -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MonitorPanelView Grid.Column="0" />
            <controls:AlarmLogTabsView Grid.Column="1" Margin="10,0,0,0" />
        </Grid>
    </Grid>
</Window>
