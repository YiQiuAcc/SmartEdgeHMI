<UserControl
    x:Class="SmartEdgeHMI.Views.Controls.ConnectionBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="clr-namespace:SmartEdgeHMI"
    xmlns:vm="clr-namespace:SmartEdgeHMI.ViewModels">

    <StackPanel Orientation="Vertical">
        <DockPanel Margin="0,0,0,5">
            <Button
                Width="42"
                Height="28"
                Padding="2,0"
                Command="{x:Static app:App.ToggleLanguageCommand}"
                Content="{DynamicResource Str_LanguageToggle}"
                DockPanel.Dock="Right"
                FontSize="12"
                ToolTip="Switch Language / 切换语言" />

            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                <Ellipse
                    Width="14"
                    Height="14"
                    Margin="5,0,8,0"
                    Fill="{Binding Connection.StatusColor, FallbackValue=Red}" />
                <TextBlock
                    Width="100"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Text="{Binding Connection.StatusText}" />

                <TextBlock
                    Margin="0,0,3,0"
                    VerticalAlignment="Center"
                    Text="{DynamicResource Str_Port}" />
                <ComboBox
                    Width="65"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding Connection.AvailablePorts}"
                    SelectedItem="{Binding Connection.SelectedPort, Mode=TwoWay}" />

                <TextBlock
                    Margin="0,0,3,0"
                    VerticalAlignment="Center"
                    Text="{DynamicResource Str_BaudRate}" />
                <ComboBox
                    Width="72"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding Connection.AvailableBaudRate}"
                    SelectedItem="{Binding Connection.SelectedBaudRate, Mode=TwoWay}" />

                <TextBlock
                    Margin="0,0,3,0"
                    VerticalAlignment="Center"
                    Text="{DynamicResource Str_Protocol}" />
                <ComboBox
                    Width="75"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding Connection.AvailableProtocols}"
                    SelectedItem="{Binding Connection.SelectedProtocol, Mode=TwoWay}" />

                <TextBlock
                    x:Name="SlaveIdLabel"
                    Margin="0,0,3,0"
                    VerticalAlignment="Center"
                    Text="Slave ID:">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Connection.SelectedProtocol}" Value="Modbus">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBox
                    x:Name="SlaveIdBox"
                    Width="35"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Text="{Binding Connection.ModbusSlaveId, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Connection.SelectedProtocol}" Value="Modbus">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button
                    Height="26"
                    MinWidth="65"
                    Margin="0,0,8,0"
                    Padding="8,0"
                    Command="{Binding Connection.ToggleConnectCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="{DynamicResource Str_Connect}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Connection.IsSelectedPortConnected}" Value="True">
                                    <Setter Property="Content" Value="{DynamicResource Str_Disconnect}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button
                    Height="26"
                    MinWidth="80"
                    Padding="10,0"
                    Command="{Binding Trend.ToggleModeCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="{DynamicResource Str_HistoryMode}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Trend.IsHistoryMode}" Value="True">
                                    <Setter Property="Content" Value="{DynamicResource Str_LiveMode}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </DockPanel>

        <StackPanel
            Margin="0,5,0,5"
            Orientation="Horizontal"
            Visibility="{Binding Trend.IsHistoryMode, Converter={StaticResource BoolToVis}}">
            <TextBlock
                Margin="0,0,5,0"
                VerticalAlignment="Center"
                Text="{DynamicResource Str_Start}" />
            <DatePicker
                Width="130"
                Margin="0,0,10,0"
                SelectedDate="{Binding Trend.StartTime}" />
            <TextBlock
                Margin="0,0,5,0"
                VerticalAlignment="Center"
                Text="{DynamicResource Str_End}" />
            <DatePicker
                Width="130"
                Margin="0,0,10,0"
                SelectedDate="{Binding Trend.EndTime}" />
            <TextBlock
                Margin="0,0,5,0"
                VerticalAlignment="Center"
                Text="{DynamicResource Str_Points}" />
            <ComboBox
                Width="70"
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                ItemsSource="{x:Static vm:TrendViewModel.TargetPointOptions}"
                SelectedItem="{Binding Trend.TargetPoints}" />
            <Button
                Width="60"
                Height="28"
                Command="{Binding Trend.LoadTrendCommand}"
                Content="{DynamicResource Str_Load}" />
        </StackPanel>
    </StackPanel>
</UserControl>
