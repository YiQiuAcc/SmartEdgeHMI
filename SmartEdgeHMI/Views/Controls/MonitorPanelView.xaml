<UserControl
    x:Class="SmartEdgeHMI.Views.Controls.MonitorPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="0,0,10,0" Orientation="Vertical">
        <TextBlock
            Margin="0,0,0,10"
            FontWeight="Bold"
            Text="{DynamicResource Str_Threshold}" />
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Str_SetValue}" />
            <TextBlock Text="{Binding ElementName=TempSlider, Path=Value}" />
            <TextBlock Text=" °C" />
        </StackPanel>
        <Slider
            x:Name="TempSlider"
            Margin="0,10,0,10"
            IsSnapToTickEnabled="True"
            LargeChange="10"
            Maximum="100"
            Minimum="0"
            SmallChange="1"
            TickFrequency="1"
            Value="{Binding Monitor.AlarmThreshold, Mode=TwoWay, FallbackValue=50}" />
        <TextBlock Text="{DynamicResource Str_CurrentValue}" />
        <TextBlock
            Margin="0,10,0,15"
            FontSize="24"
            FontWeight="Bold"
            Text="{Binding Monitor.CurrentTemperature, StringFormat={}{0:F1} °C}" />
        <Button
            Height="40"
            VerticalAlignment="Center"
            Command="{Binding Monitor.ResetDeviceCommand}"
            Content="{DynamicResource Str_ResetDevice}"
            Style="{StaticResource DangerButtonStyle}" />
    </StackPanel>
</UserControl>
