<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!--  连接面板  -->
    <system:String x:Key="Str_Port">端口:</system:String>
    <system:String x:Key="Str_BaudRate">波特率:</system:String>
    <system:String x:Key="Str_Protocol">协议:</system:String>
    <system:String x:Key="Str_Connect">连接</system:String>
    <system:String x:Key="Str_Disconnect">断开</system:String>
    <system:String x:Key="Str_NotConnected">未连接</system:String>
    <system:String x:Key="Str_LanguageToggle">EN</system:String>
    <system:String x:Key="Str_ConnectedTo">已连接</system:String>
    <system:String x:Key="Str_ConnectedMulti">已连接 {0} 个端口</system:String>

    <!--  趋势图  -->
    <system:String x:Key="Str_HistoryMode">历史模式</system:String>
    <system:String x:Key="Str_LiveMode">实时模式</system:String>
    <system:String x:Key="Str_Start">起始:</system:String>
    <system:String x:Key="Str_End">结束:</system:String>
    <system:String x:Key="Str_Points">点数:</system:String>
    <system:String x:Key="Str_Load">加载</system:String>

    <!--  报警  -->
    <system:String x:Key="Str_AlarmView">报警视图</system:String>
    <system:String x:Key="Str_SystemLog">系统日志</system:String>
    <system:String x:Key="Str_AcknowledgeAll">一键确认全部</system:String>
    <system:String x:Key="Str_Acknowledge">确认</system:String>
    <system:String x:Key="Str_Time">时间</system:String>
    <system:String x:Key="Str_DeviceId">设备编号</system:String>
    <system:String x:Key="Str_AlarmCode">报警代码</system:String>
    <system:String x:Key="Str_Status">状态</system:String>
    <system:String x:Key="Str_Action">操作</system:String>

    <!--  阈值  -->
    <system:String x:Key="Str_Threshold">温度报警阈值设置</system:String>
    <system:String x:Key="Str_SetValue">设置值:</system:String>
    <system:String x:Key="Str_CurrentValue">当前值:</system:String>
    <system:String x:Key="Str_ResetDevice">⚠️ 设备紧急复位 (Reset)</system:String>
</ResourceDictionary>
