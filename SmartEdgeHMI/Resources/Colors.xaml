<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  主色调  -->
    <Color x:Key="PrimaryBgColor">#1E1E1E</Color>
    <Color x:Key="SecondaryBgColor">#252526</Color>
    <Color x:Key="SurfaceBgColor">#2E2E2E</Color>

    <!--  文本色  -->
    <Color x:Key="PrimaryTextColor">#CCCCCC</Color>
    <Color x:Key="SecondaryTextColor">#999999</Color>

    <!--  语义色  -->
    <Color x:Key="ErrorColor">#E74856</Color>
    <Color x:Key="WarningColor">#F9A825</Color>
    <Color x:Key="SuccessColor">#16C60C</Color>
    <Color x:Key="InfoColor">#3B99FC</Color>

    <!--  强调色  -->
    <Color x:Key="AccentColor">#0078D4</Color>

    <!--  SolidColorBrush 引用  -->
    <SolidColorBrush x:Key="PrimaryBgBrush" Color="{StaticResource PrimaryBgColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
</ResourceDictionary>
